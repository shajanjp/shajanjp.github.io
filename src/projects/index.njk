---
layout: layouts/base.njk
title: Projects
description: "Personal hobby projects I have built"
eleventyExcludeFromCollections: true
eleventyAllowMissingExtension: true

pagination:
  data: collections.projects
  size: 20
  reverse: true
  alias: projects
permalink: "/projects/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---

<section>
    <h2 class="text-2xl font-medium mb-8">Experiments / Tools / Initiatives</h2>
    <div class="">
        {% for project in projects %}
        <article class="mt-6">
            <a class="mt-4" href="{{ project.url }}" class="group block">
                <h3 class="font-medium decoration-zinc-400">{{ project.data.title }}</h3>
            </a>
            <p class="mt-1 text-sm text-justify text-zinc-500 dark:text-zinc-400">{{ project.data.description }}</p>
            <span class="text-xs text-zinc-400 dark:text-zinc-600">{{ project.date | humanDate }}</span>
        </article>
        {% endfor %}
    </div>
    {% set entityName = "projects" %}
    {% include "components/pagination-nav.njk" %}
</section>
