---
layout: layouts/base.njk
title: Project Tags
eleventyExcludeFromCollections: true
permalink: /projects/tag/
---

<section>
  <h2 class="text-2xl font-medium mb-8">All Project Tags</h2>
  <div class="flex flex-wrap gap-3">
    {% for tag, items in collections %}
      {% if tag not in ["all", "blog", "posts", "photos", "projects"] %}
        {% set projectCount = 0 %}
        {% for item in items %}
          {% if "projects" in item.data.tags %}
            {% set projectCount = projectCount + 1 %}
          {% endif %}
        {% endfor %}
        
        {% if projectCount > 0 %}
          <a href="/projects/tag/{{ tag }}/" class="px-3 py-1 border border-zinc-200 dark:border-zinc-800 rounded-md hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors">
            <span class="text-sm font-medium">{{ tag }}</span>
            <span class="text-xs text-zinc-500 ml-1">({{ projectCount }})</span>
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>
