<div class="relative flex flex-row items-start sm:items-center gap-4 sm:gap-6 py-2 border-b border-zinc-100 dark:border-zinc-800 last:border-0">
    <!-- Content Section -->
    <div class="flex-1 min-w-0">
        <div class="text-[10px] text-zinc-400 dark:text-zinc-600 mb-1 uppercase tracking-widest font-semibold">
            {{ project.date | humanDate }}
        </div>

        <a href="{{ project.url }}" class="block">
            <h3 class="text-lg font-medium leading-tight mb-2 text-zinc-900 dark:text-zinc-100 transition-colors break-words">
                {{ project.data.title }}
            </h3>
        </a>

        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
            {{ project.data.description }}
        </p>

        <div class="flex flex-wrap gap-2">
            {% for tag in project.data.tags %}
            {% if tag != "blog" %}
            <a href="/projects/tag/{{ tag }}/" class="text-[10px] uppercase tracking-wider px-2 py-0.5 border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-500 rounded-sm hover:border-zinc-900 dark:hover:border-zinc-100 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all duration-300">
                {{ tag }}
            </a>
            {% endif %}
            {% endfor %}
        </div>
    </div>

    <!-- Icon/Cover Section -->
    <div class="w-16 h-16 sm:w-32 sm:h-32 flex-shrink-0 overflow-hidden flex items-center justify-center order-first sm:order-last">
        <!-- Example Container -->
        <div class="flex justify-center">
          <img src="{{ project.url }}{{ project.data.icon }}" alt="{{ project.data.title }} - icon"
            class="w-10 h-auto transition-all duration-300 invert-40 dark:invert-70"
          >
        </div>
    </div>
</div>
