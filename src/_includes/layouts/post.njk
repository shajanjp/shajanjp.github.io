---
layout: layouts/base.njk
---
<article>
    <header class="mb-8 not-prose">
        <h1 class="text-3xl font-bold tracking-tight mb-10">{{ title }}</h1>
        <p class="mt-2 text-lg">{{ description }}</p>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">{{ page.date | humanDate }}</p>
        <div class="mt-2 flex gap-2">
            {% for tag in tags %}
            {% if tag != "posts" and tag != "blog" %}
            <a href="/blog/tag/{{ tag }}/" class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 border border-zinc-200 dark:border-zinc-800 text-zinc-500 rounded-sm transition-all hover:border-zinc-300 dark:hover:border-zinc-700">{{ tag }}</a>
            {% endif %}
            {% endfor %}
        </div>
    </header>
    <div class="prose dark:prose-invert text-justify max-w-none">
        {{ content | safe }}
    </div>
</article>
