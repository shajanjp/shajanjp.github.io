---
layout: layouts/base.njk
---
{% if tags and "blog" in tags %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "{{ site.url }}{{ page.url }}",
  "datePublished": "{{ page.date | htmlDateString }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}"
  }{% if thumbnail %},
  "image": "{{ site.url }}{{ page.url }}{{ thumbnail }}"{% endif %}
}
</script>
{% elif tags and "photos" in tags %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Photograph",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "url": "{{ site.url }}{{ page.url }}",
  "dateCreated": "{{ page.date | htmlDateString }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}"
  }{% if image %},
  "contentUrl": "{{ site.url }}{{ page.url }}{{ image }}"{% endif %}
}
</script>
{% endif %}
<article>
    <header class="mb-8 not-prose">
        <div class="relative flex flex-row items-start sm:items-center gap-4 sm:gap-6 py-1 border-b border-zinc-100 dark:border-zinc-800 last:border-0">
            <!-- Content Section -->
            <div class="flex-1 min-w-0">
                <div class="text-base  text-zinc-400 dark:text-zinc-600 mb-4 uppercase tracking-widest font-semibold">
                    {{ page.date | humanDate }}
                </div>

                <div  class="block">
                    <h3 class="text-2xl font-medium leading-tight mb-4 text-zinc-900 dark:text-zinc-100 transition-colors break-words">
                        {{ title }}
                    </h3>
                </div>

                <p class="text-md text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
                    {{ description }}
                </p>

                <div class="flex flex-wrap gap-2">
                    {% for tag in tags %}
                    {% if tag != "blog" %}
                    <a href="/blog/tag/{{ tag }}/" class="text-xs uppercase tracking-wider px-2 py-0.5 border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-500 rounded-sm hover:border-zinc-900 dark:hover:border-zinc-100 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all duration-300">
                        {{ tag }}
                    </a>
                    {% endif %}
                    {% endfor %}
                </div>
            </div>

            <!-- Icon/Cover Section -->
            <div class="w-8 h-8 sm:w-48 sm:h-48 flex-shrink-0 overflow-hidden flex items-center justify-center order-first sm:order-last">
                <!-- Example Container -->
                <div class="flex justify-center">
                  <img src="{{ project.url }}{{icon }}" alt="{{ title }} - icon"
                    class="w-8 sm:w-24 h-auto transition-all duration-300 invert-40 dark:invert-70"
                  >
                </div>
            </div>
        </div>
    </header>
    <div class="prose dark:prose-invert max-w-none">
        {{ content | safe }}
    </div>

    {% if relatedPosts and relatedPosts.length %}
    <hr class="mt-16 border-zinc-200 dark:border-zinc-800">
    <div class="not-prose mt-8">
        <h2 class="text-xl font-medium mb-6 text-zinc-700 dark:text-zinc-300">Related Posts</h2>
        <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
            {% for slug in relatedPosts %}
            {% itemEmbed "blog", slug %}
            {% endfor %}
        </div>
    </div>
    {% endif %}
</article>
