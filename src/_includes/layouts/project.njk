---
layout: layouts/base.njk
---
<article>
    <header class="mb-8 not-prose">
        <h1 class="text-3xl font-bold tracking-tight mb-10">{{ title }}</h1>
        <p class="mt-2 text-lg">{{ description }}</p>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">{{ page.date | humanDateYearMonth }}</p>
        <div class="mt-2 mt-4flex gap-2">
            {% for tag in tags %}
            {% if tag != "projects" %}
            <a href="/projects/tag/{{ tag }}/" class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 border border-zinc-200 dark:border-zinc-800 text-zinc-500 rounded-sm transition-all translate-0.5 hover:border-zinc-300 dark:hover:border-zinc-700">{{ tag }}</a>
            {% endif %}
            {% endfor %}
        </div>
    </header>
    <div class="prose dark:prose-invert text-justify max-w-none">
        {{ content | safe }}
    </div>
    <div class="mt-8 flex flex-col gap-3 items-start">
        <a class="px-5 py-2 font-mono text-xs uppercase tracking-[0.2em] transition-colors duration-150 bg-transparent text-neutral-600 border border-neutral-300 hover:text-neutral-900 hover:border-neutral-900 dark:text-neutral-500 dark:border-neutral-800 dark:hover:text-neutral-200 dark:hover:border-neutral-500 focus:outline-none active:opacity-70" href="{{sourceCodeUrl}}">View Source Code</a>
        <a class="px-5 py-2 font-mono text-xs uppercase tracking-[0.2em] transition-colors duration-150 bg-transparent text-neutral-600 border border-neutral-300 hover:text-neutral-900 hover:border-neutral-900 dark:text-neutral-500 dark:border-neutral-800 dark:hover:text-neutral-200 dark:hover:border-neutral-500 focus:outline-none active:opacity-70" href="{{livePreviewUrl}}">View Live Preview</a>
    </div>
</article>
