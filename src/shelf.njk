---
layout: layouts/base.njk
title: "Shelf"
description: "Books I have"
---

<section>
  <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-600 mb-6">Shelf</h2>

  <div id="book-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-x-3 gap-y-6">
    <div class="col-span-full text-center text-sm text-zinc-500 dark:text-zinc-400 py-12" id="loading-state">Loading books...</div>
  </div>
</section>

<script>


  (async function () {
    const grid = document.getElementById('book-grid');
    const loading = document.getElementById('loading-state');

    try {
      const res = await fetch('https://website-utils.sj.deno.net/api/books');
      if (!res.ok) throw new Error('Failed to fetch');
      const books = await res.json();

      loading.remove();

      books.forEach(book => {
        const authors = book.authors?.map(a => a.name).join(', ') || '';
        const tooltip = `${book.title}${authors ? ' - ' + authors : ''}`;
        const completionPercentage = book.completionPercentage ?? 0;

        // Card wrapper
        const item = document.createElement('div');
        item.className = 'group cursor-default';

        // Image container
        const imgWrap = document.createElement('div');
        imgWrap.className = 'bg-zinc-100 dark:bg-zinc-900 rounded-sm overflow-hidden relative';
        imgWrap.style.aspectRatio = '3 / 4';

        const img = document.createElement('img');
        img.src = book.thumbnail;
        img.alt = book.title;
        img.title = tooltip;
        img.className =
          'w-full h-full object-cover transition-all duration-500 grayscale group-hover:grayscale-0';
        img.loading = 'lazy';

        imgWrap.appendChild(img);
        item.appendChild(imgWrap);

        // Status badge
        let badge;
        if (completionPercentage >= 100) {
          badge = document.createElement('div');
          badge.className =
            'mt-1.5 flex items-center gap-1 text-xs text-green-600 dark:text-green-400';
          badge.innerHTML =
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>' +
            '<span>Read</span>';
        } else if (completionPercentage > 0) {
          badge = document.createElement('div');
          badge.className =
            'mt-1.5 flex items-center gap-1 text-xs text-yellow-600 dark:text-yellow-400';
          badge.innerHTML =
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>' +
            '<span>In Progress</span>';
        } else {
          badge = document.createElement('div');
          badge.className =
            'mt-1.5 flex items-center gap-1 text-xs text-zinc-400 dark:text-zinc-600';
          badge.innerHTML =
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>' +
            '<span>Unread</span>';
        }
        item.appendChild(badge);

        grid.appendChild(item);
      });
    } catch (err) {
      loading.textContent = 'Failed to load books.';
      console.error(err);
    }
  })();
</script>
