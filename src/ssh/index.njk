<body>
<style>
    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #000000;
        font-family: "IBM Plex Mono", monospace;
        font-size: 16px;
        line-height: 1.5;
        color: #cccccc;
        display: flex;
        flex-direction: column;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
    }

    .terminal-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #111111;
        border-bottom: 1px solid #1a1a1a;
        padding: 4px 12px;
        flex-shrink: 0;
        user-select: none;
    }

    .terminal-topbar-left {
        font-size: 12px;
        color: #666;
    }

    .terminal-topbar-right a {
        color: #666;
        text-decoration: none;
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 4px;
        transition: background 0.15s, color 0.15s;
    }

    .terminal-topbar-right a:hover {
        background: #1a1a1a;
        color: #aaa;
    }

    .terminal-body {
        flex: 1;
        overflow-y: auto;
        padding: 4px 16px 8px;
        scroll-behavior: smooth;
        word-break: break-word;
    }

    .terminal-body::-webkit-scrollbar {
        width: 6px;
    }
    .terminal-body::-webkit-scrollbar-track {
        background: transparent;
    }
    .terminal-body::-webkit-scrollbar-thumb {
        background: #222;
        border-radius: 3px;
    }

    .terminal-line {
        margin-bottom: 0;
        white-space: pre-wrap;
    }

    .terminal-input-line {
        display: flex;
        align-items: center;
        gap: 0;
        white-space: nowrap;
    }

    .prompt { color: #00cc00; }
    .directory { color: #6699ff; }
    .command { color: #ffffff; }

    #terminal-input {
        background: transparent;
        border: none;
        outline: none;
        color: #ffffff;
        font-family: "IBM Plex Mono", monospace;
        font-size: 16px;
        flex: 1;
        caret-color: #00cc00;
        padding: 0;
        margin-left: 6px;
        min-width: 0;
    }

    .output-info { color: #00cc00; }
    .output-error { color: #cc3333; }
    .output-highlight { color: #6699ff; }
    .output-dim { color: #666666; }
    .output-default { color: #cccccc; }
</style>

<div class="terminal-topbar">
    <span class="terminal-topbar-left">guest@shajanjacob.com вЂ” bash</span>
    <span class="terminal-topbar-right">
        <a href="/">в†ђ back to site</a>
    </span>
</div>

