{% endif %}{% if item.data.livePreviewUrl %}Live: <a href="{{ item.data.livePreviewUrl }}" target="_blank" class="output-highlight" style="text-decoration:underline">{{ item.data.livePreviewUrl }}</a>
{% endif %}{% if userTags.length %}Tags: {{ userTags | join(", ") }}
{% endif %}{%- endset %}
