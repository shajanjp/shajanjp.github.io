{% if item.data.date %}Date: {{ item.data.date | htmlDateString }}
{% endif %}Description: {{ item.data.description }}
{% if userTags.length %}Tags: {{ userTags | join(", ") }}
{% endif %}{% if item.data.tldr %}
TL;DR: {{ item.data.tldr }}
