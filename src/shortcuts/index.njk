---
layout: layouts/base.njk
title: Apple Shortcuts
description: "Apple Shortcuts I use frequently"
eleventyExcludeFromCollections: true
eleventyAllowMissingExtension: true

pagination:
  data: collections.shortcuts
  size: 20
  reverse: true
  alias: shortcuts
permalink: "/shortcuts/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---

<section>
    <h2 class="text-2xl font-medium mb-8">Apple Shortcuts</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {% for shortcut in shortcuts %}
            {% include "components/shortcut-card.njk" %}
        {% endfor %}
    </div>
</section>
