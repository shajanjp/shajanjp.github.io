---
layout: layouts/base.njk
title: Contact
description: "Get in touch with me."
---

<section class="space-y-16">
    <div>
        <h2 class="text-2xl font-medium mb-6">Send a message</h2>
        <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label for="name" class="block text-xs uppercase tracking-widest text-zinc-400 dark:text-zinc-600">Name</label>
                    <input type="text" id="name" name="name" required class="w-full bg-transparent border-b border-zinc-200 dark:border-zinc-800 py-2 focus:border-zinc-900 dark:focus:border-zinc-100 outline-none transition-colors text-zinc-800 dark:text-zinc-200">
                </div>
                <div class="space-y-2">
                    <label for="email" class="block text-xs uppercase tracking-widest text-zinc-400 dark:text-zinc-600">Email</label>
                    <input type="email" id="email" name="email" required class="w-full bg-transparent border-b border-zinc-200 dark:border-zinc-800 py-2 focus:border-zinc-900 dark:focus:border-zinc-100 outline-none transition-colors text-zinc-800 dark:text-zinc-200">
                </div>
            </div>
            <div class="space-y-2">
                <label for="message" class="block text-xs uppercase tracking-widest text-zinc-400 dark:text-zinc-600">Message</label>
                <textarea id="message" name="message" rows="4" required class="w-full bg-transparent border-b border-zinc-200 dark:border-zinc-800 py-2 focus:border-zinc-900 dark:focus:border-zinc-100 outline-none transition-colors resize-none text-zinc-800 dark:text-zinc-200"></textarea>
            </div>
            <div class="flex items-center justify-between">
                <div id="form-status" class="text-sm transition-opacity duration-300 opacity-0"></div>
                <button type="submit" class="text-xs uppercase tracking-widest px-6 py-3 border border-zinc-200 dark:border-zinc-800 hover:border-zinc-900 dark:hover:border-zinc-100 hover:bg-zinc-900 hover:text-white dark:hover:bg-zinc-100 dark:hover:text-black transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed">
                    Send Message
                </button>
            </div>
        </form>
    </div>

    <div class="pt-8 dark:border-zinc-800">
        {% include "components/social-links.njk" %}
    </div>
</section>

<script>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        status.textContent = 'Sending...';
        status.classList.remove('opacity-0', 'text-red-500', 'text-green-500');
        status.classList.add('opacity-100', 'text-zinc-500');

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('https://website-utils.sj.deno.net/api/contact', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            });

            if (response.ok) {
                status.textContent = 'Message sent successfully!';
                status.classList.replace('text-zinc-500', 'text-green-500');
                form.reset();
            } else {
                throw new Error('Failed to send message');
            }
        } catch (error) {
            status.textContent = 'Failed to send message. Please try again.';
            status.classList.replace('text-zinc-500', 'text-red-500');
        } finally {
            submitBtn.disabled = false;
            setTimeout(() => {
                status.classList.replace('opacity-100', 'opacity-0');
            }, 5000);
        }
    });
</script>
