<script>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        status.textContent = 'Sending...';
        status.classList.remove('opacity-0', 'text-red-500', 'text-green-500');
        status.classList.add('opacity-100', 'text-zinc-500');

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('/api/send-message', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            });

            if (response.ok) {
                status.textContent = 'Message sent successfully!';
                status.classList.replace('text-zinc-500', 'text-green-500');
                form.reset();
            } else {
                throw new Error('Failed to send message');
            }
        } catch (error) {
            status.textContent = 'Failed to send message. Please try again.';
            status.classList.replace('text-zinc-500', 'text-red-500');
        } finally {
            submitBtn.disabled = false;
            setTimeout(() => {
                status.classList.replace('opacity-100', 'opacity-0');
            }, 5000);
        }
    });
</script>
