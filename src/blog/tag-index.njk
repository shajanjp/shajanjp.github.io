---
layout: layouts/base.njk
title: Blog Tags
eleventyExcludeFromCollections: true
permalink: /blog/tag/
---

<section>
  <h2 class="text-2xl font-medium mb-8">All Blog Tags</h2>
  <div class="flex flex-wrap gap-3">
    {% for tag, posts in collections %}
      {% if tag not in ["all", "blog", "posts", "photos", "projects"] %}
        {% set blogCount = 0 %}
        {% for post in posts %}
          {% if "blog" in post.data.tags %}
            {% set blogCount = blogCount + 1 %}
          {% endif %}
        {% endfor %}

        {% if blogCount > 0 %}
          <a href="/blog/tag/{{ tag }}/" class="px-3 py-1 border border-zinc-300 dark:border-zinc-700 text-zinc-600 dark:text-zinc-400 rounded-sm hover:border-zinc-900 dark:hover:border-zinc-100 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all duration-300">
            <span class="text-sm font-medium">{{ tag }}</span>
            <span class="text-xs text-zinc-500 ml-1">({{ blogCount }})</span>
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>
