---
layout: layouts/base.njk
title: Blog
eleventyExcludeFromCollections: true
eleventyAllowMissingExtension: true

pagination:
  data: collections.blog
  size: 10
  reverse: true
  alias: posts
permalink: "/blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---

<section>
  <h2 class="text-2xl font-medium mb-8">Thoughts / Notes / Stories</h2>
  <div class="space-y-1">
    {% for post in posts %}
        {% include "components/blog-card.njk" %}
    {% endfor %}
  </div>
  {% set entityName = "posts" %}
  {% include "components/pagination-nav.njk" %}
</section>
